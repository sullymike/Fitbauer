        Colaboraciones
      </a></li>
      
    </ul>

    <div class="lang-toggle">
      
      <a class="lang-opt active" href="?lang=es">ES</a>
      <span class="lang-sep">/</span>
      <a class="lang-opt " href="?lang=en">EN</a>
    </div>
  </nav>
</header>


<main id="main">
  
<section class="section page-section">
  <div class="container portal-auth-container">
    <div class="portal-auth-card">
      <p class="section-tag">Portal MATELEC</p>
      <h1>Acceso al portal</h1>
      <p class="portal-subtitle">Inicia sesión para editar tu perfil, tus nombres de autor y tus publicaciones.</p>

      <form method="post" class="portal-auth-form" novalidate>
        <input type="hidden" name="csrfmiddlewaretoken" value="yqcfbrnxqRp1tmSgOAqe3SN7sqiUATHtohS6x5GlxXtm7m3jZHqJjZIY57MPKoaB">

        

        <div class="portal-form-row">
          <label for="id_username">Usuario</label>
          <input
            type="text"
            name="username"
            id="id_username"
            autocomplete="username"
            class="portal-input"
            value=""
            required
          />
          
        </div>

        <div class="portal-form-row">
          <label for="id_password">Contraseña</label>
          <input
            type="password"
            name="password"
            id="id_password"
            autocomplete="current-password"
            class="portal-input"
            required
          />
          
        </div>

        
        <input type="hidden" name="next" value="/lab/mossbauer/" />
        

        <button type="submit" class="btn btn-primary">Entrar</button>
      </form>
    </div>
  </div>
</section>

</main>

