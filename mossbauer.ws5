<body>

<!-- ===== HEADER ===== -->

<header id="header">
  <nav class="nav-container">
    <a href="/" class="logo">
      <img src="/static/img/logo5.0f0d926c78bd.png" alt="MATELEC" class="logo-img" />
      <div class="logo-text">
        <span class="logo-name">MATELEC</span>
        <span class="logo-sub">Universidad Autónoma de Madrid</span>
      </div>
    </a>

    <button class="nav-toggle" id="navToggle" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav-links" id="navLinks">
      <!-- Investigación dropdown -->
      <li class="nav-dropdown">
        <a href="/investigacion/" class="nav-dropdown-toggle ">
          Investigación <span class="nav-arrow">▾</span>
        </a>
        <ul class="nav-dropdown-menu">
          <li><a href="/investigacion/">
